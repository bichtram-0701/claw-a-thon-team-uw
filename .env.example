# Copy to .env and fill in locally. NEVER commit or share .env.

# GreenNode / AgentBase deploy credentials
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# MaaS OpenAI-compatible chat endpoint
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=
LLM_TIMEOUT=25
LLM_ENABLE_THINKING=false

# Synthetic Atlassian workspace
ATLASSIAN_SITE=https://your-site.atlassian.net
ATLASSIAN_EMAIL=
ATLASSIAN_TOKEN=
JIRA_PROJECT_KEY=UW
CONFLUENCE_SPACE_KEY=
CONFLUENCE_SPACE_ID=

# Demo default: writes enabled for the seeded workspace. Set false for read-only/local safety.
ALLOW_WRITES=true

# Optional Teams notifications
TEAMS_WEBHOOK_URL=
JIRA_EVENT_TOKEN=
APP_VERSION=demo-v13

# Routing: natural, warn, or strict. warn = prefix exact routing, warnings for non-prefixed read-only prompts, prefix required for writes.
ROUTING_MODE=warn

# Optional overrides for Jira default assignees. If unset, Watchtower infers
# stage owners from the Epic -> task structure in Jira.
DEFAULT_STAGE_OWNER_TRAFFIC=
DEFAULT_STAGE_OWNER_SUBMISSION=
DEFAULT_STAGE_OWNER_APPROVAL=
DEFAULT_STAGE_OWNER_COMPLETION=
DEFAULT_STAGE_OWNER_CROSSCUT=
