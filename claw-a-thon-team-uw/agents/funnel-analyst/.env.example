# --- GreenNode MaaS (OpenAI-compatible) ---
# Get an API key from https://aiplatform.console.greennode.ai/api-keys
# or use the team token from the Claw-a-thon Training-day welcome email.

# Base URL of the OpenAI-compatible endpoint. Do NOT include /chat/completions.
# (Verified MaaS endpoint used by the team repo.)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Your MaaS API key (Bearer token).
LLM_API_KEY=

# Model to use — the contest provides these self-hosted models:
#   gemma-4-31b-it   or   Qwen-3-27B
LLM_MODEL=gemma-4-31b-it
